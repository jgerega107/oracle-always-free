# Optional OpenTofu remote state backend for SeaweedFS S3.
#
# To enable:
#   1. Copy this file to backend.tf.
#   2. Set AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY for SeaweedFS.
#   3. Set TF_VAR_state_encryption_passphrase to a long passphrase.
#   4. Run: tofu init -migrate-state
#
# Do not commit backend.tf if it contains environment-specific endpoints.

variable "state_encryption_passphrase" {
  description = "Passphrase for OpenTofu state encryption. Set with TF_VAR_state_encryption_passphrase. Must be at least 16 characters."
  type        = string
  sensitive   = true
}

terraform {
  backend "s3" {
    bucket = "tofu-state"
    key    = "oci-free-server/terraform.tfstate"
    region = "us-east-1"

    endpoints = {
      s3 = "http://127.0.0.1:8333"
    }

    use_path_style              = true
    skip_credentials_validation = true
    skip_metadata_api_check     = true
    skip_region_validation      = true
    skip_requesting_account_id  = true
    skip_s3_checksum            = true

    # OpenTofu S3-native lockfile support. If SeaweedFS rejects the conditional
    # write behavior in your version, remove this line and avoid concurrent applies.
    use_lockfile = true
  }

  encryption {
    # For an existing unencrypted local state, keep this fallback for the first
    # migration/apply only. After state has been written encrypted, remove the
    # fallback block below and set enforced = true.
    method "unencrypted" "migration" {}

    key_provider "pbkdf2" "state" {
      passphrase               = var.state_encryption_passphrase
      key_length               = 32
      iterations               = 600000
      salt_length              = 32
      hash_function            = "sha512"
      encrypted_metadata_alias = "oci-free-server-state"
    }

    method "aes_gcm" "state" {
      keys = key_provider.pbkdf2.state
    }

    state {
      method = method.aes_gcm.state

      fallback {
        method = method.unencrypted.migration
      }

      # Enable after the first successful encrypted migration/apply.
      # enforced = true
    }

    plan {
      method = method.aes_gcm.state

      fallback {
        method = method.unencrypted.migration
      }

      # Enable after the first successful encrypted migration/apply.
      # enforced = true
    }
  }
}
